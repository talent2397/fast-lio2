<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="fastlio_world">

    <!-- ====== DART 真实物理 ====== -->
    <physics name="1ms" type="dart">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
      <dart>
        <solver_type>dantzig</solver_type>
      </dart>
    </physics>

    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-imu-system" name="gz::sim::systems::Imu"/>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.9 0.9 0.9</diffuse>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!-- ====== 地面 ====== -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="c"><geometry><box><size>60 60 0.1</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>60 60 0.1</size></box></geometry>
          <material><ambient>0.6 0.6 0.6</ambient><diffuse>0.7 0.7 0.7</diffuse></material></visual>
      </link>
    </model>

    <!-- ====== 四面围墙 (10m×10m 场景) ====== -->
    <model name="wall_n"><static>true</static><pose>0 8 2 0 0 0</pose>
      <link name="l"><collision name="c"><geometry><box><size>16 0.4 4</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>16 0.4 4</size></box></geometry>
          <material><ambient>0.8 0.3 0.2</ambient><diffuse>0.85 0.35 0.25</diffuse></material></visual></link></model>
    <model name="wall_s"><static>true</static><pose>0 -8 2 0 0 0</pose>
      <link name="l"><collision name="c"><geometry><box><size>16 0.4 4</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>16 0.4 4</size></box></geometry>
          <material><ambient>0.2 0.3 0.8</ambient><diffuse>0.25 0.35 0.85</diffuse></material></visual></link></model>
    <model name="wall_e"><static>true</static><pose>8 0 2 0 0 1.57</pose>
      <link name="l"><collision name="c"><geometry><box><size>16 0.4 4</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>16 0.4 4</size></box></geometry>
          <material><ambient>0.3 0.7 0.2</ambient><diffuse>0.35 0.75 0.25</diffuse></material></visual></link></model>
    <model name="wall_w"><static>true</static><pose>-8 0 2 0 0 1.57</pose>
      <link name="l"><collision name="c"><geometry><box><size>16 0.4 4</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>16 0.4 4</size></box></geometry>
          <material><ambient>0.8 0.6 0.1</ambient><diffuse>0.85 0.65 0.15</diffuse></material></visual></link></model>

    <!-- ====== 内部障碍物 (4柱 + 6方块 + 1斜坡) ====== -->
    <model name="pillar_1"><static>true</static><pose>3 3 2 0 0 0</pose>
      <link name="l"><collision name="c"><geometry><cylinder><radius>0.4</radius><length>4</length></cylinder></geometry></collision>
        <visual name="v"><geometry><cylinder><radius>0.4</radius><length>4</length></cylinder></geometry>
          <material><ambient>0.5 0.5 0.5</ambient><diffuse>0.6 0.6 0.6</diffuse></material></visual></link></model>
    <model name="pillar_2"><static>true</static><pose>-3 3 2 0 0 0</pose>
      <link name="l"><collision name="c"><geometry><cylinder><radius>0.3</radius><length>4</length></cylinder></geometry></collision>
        <visual name="v"><geometry><cylinder><radius>0.3</radius><length>4</length></cylinder></geometry>
          <material><ambient>0.4 0.4 0.5</ambient><diffuse>0.5 0.5 0.6</diffuse></material></visual></link></model>
    <model name="pillar_3"><static>true</static><pose>3 -3 2 0 0 0</pose>
      <link name="l"><collision name="c"><geometry><cylinder><radius>0.35</radius><length>4</length></cylinder></geometry></collision>
        <visual name="v"><geometry><cylinder><radius>0.35</radius><length>4</length></cylinder></geometry>
          <material><ambient>0.5 0.4 0.4</ambient><diffuse>0.6 0.5 0.5</diffuse></material></visual></link></model>
    <model name="pillar_4"><static>true</static><pose>-3 -3 2 0 0 0</pose>
      <link name="l"><collision name="c"><geometry><cylinder><radius>0.25</radius><length>4</length></cylinder></geometry></collision>
        <visual name="v"><geometry><cylinder><radius>0.25</radius><length>4</length></cylinder></geometry>
          <material><ambient>0.45 0.5 0.4</ambient><diffuse>0.55 0.6 0.5</diffuse></material></visual></link></model>

    <model name="box_1"><static>true</static><pose>5 2 0.6 0 0 0.3</pose>
      <link name="l"><collision name="c"><geometry><box><size>1 1 1.2</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>1 1 1.2</size></box></geometry>
          <material><ambient>0.7 0.4 0.2</ambient><diffuse>0.8 0.5 0.3</diffuse></material></visual></link></model>
    <model name="box_2"><static>true</static><pose>-5 2 0.5 0 0 0.1</pose>
      <link name="l"><collision name="c"><geometry><box><size>0.8 0.8 1</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.8 0.8 1</size></box></geometry>
          <material><ambient>0.3 0.5 0.7</ambient><diffuse>0.35 0.55 0.75</diffuse></material></visual></link></model>
    <model name="box_3"><static>true</static><pose>2 5 0.7 0 0 0</pose>
      <link name="l"><collision name="c"><geometry><box><size>1.2 0.6 1.4</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>1.2 0.6 1.4</size></box></geometry>
          <material><ambient>0.5 0.3 0.6</ambient><diffuse>0.55 0.35 0.65</diffuse></material></visual></link></model>
    <model name="box_4"><static>true</static><pose>-2 -5 0.5 0 0 0.2</pose>
      <link name="l"><collision name="c"><geometry><box><size>0.9 0.9 1</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.9 0.9 1</size></box></geometry>
          <material><ambient>0.6 0.5 0.2</ambient><diffuse>0.65 0.55 0.25</diffuse></material></visual></link></model>
    <model name="box_5"><static>true</static><pose>6 -1 0.8 0 0 0</pose>
      <link name="l"><collision name="c"><geometry><box><size>0.6 1.0 1.6</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.6 1.0 1.6</size></box></geometry>
          <material><ambient>0.3 0.6 0.3</ambient><diffuse>0.35 0.65 0.35</diffuse></material></visual></link></model>
    <model name="box_6"><static>true</static><pose>-6 3 0.5 0 0 0.15</pose>
      <link name="l"><collision name="c"><geometry><box><size>0.7 1.3 1</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.7 1.3 1</size></box></geometry>
          <material><ambient>0.7 0.2 0.5</ambient><diffuse>0.75 0.25 0.55</diffuse></material></visual></link></model>

    <model name="ramp"><static>true</static><pose>-4 -4 0.5 0 0.5 0</pose>
      <link name="l"><collision name="c"><geometry><box><size>3 1.5 0.3</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>3 1.5 0.3</size></box></geometry>
          <material><ambient>0.4 0.4 0.4</ambient><diffuse>0.5 0.5 0.5</diffuse></material></visual></link></model>

    <!-- ================================================================
         传感器小车 (差速驱动)
         底盘尺寸: 0.8×0.5×0.4m, 轮半径 0.2m, 轮距 0.7m
         LiDAR 可见圆柱在顶部, IMU 可见方块在底盘内
    ================================================================ -->
    <model name="sensor_cart">
      <pose>0 0 0.4 0 0 0</pose>

      <!-- ====== 底盘 ====== -->
      <link name="chassis">
        <inertial><mass>5.0</mass>
          <inertia><ixx>1.0</ixx><ixy>0</ixy><ixz>0</ixz><iyy>1.0</iyy><iyz>0</iyz><izz>1.0</izz></inertia>
        </inertial>
        <collision name="c"><geometry><box><size>0.8 0.5 0.4</size></box></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface>
        </collision>
        <visual name="v"><geometry><box><size>0.8 0.5 0.4</size></box></geometry>
          <material><ambient>0.3 0.3 0.35</ambient><diffuse>0.4 0.4 0.5</diffuse></material>
        </visual>

        <!-- IMU 传感器 (在底盘中心) -->
        <sensor name="imu" type="imu">
          <topic>/imu0</topic>
          <always_on>1</always_on>
          <update_rate>400</update_rate>
        </sensor>

        <!-- 3D LiDAR 传感器 (VLP-16 参数, 安装在顶板上) -->
        <sensor name="lidar" type="gpu_lidar">
          <topic>/lidar0</topic>
          <update_rate>10</update_rate>
          <pose>0 0 0.3 0 0 0</pose>
          <lidar>
            <scan>
              <horizontal>
                <samples>1800</samples>
                <resolution>1</resolution>
                <min_angle>-3.14159</min_angle>
                <max_angle>3.14159</max_angle>
              </horizontal>
              <vertical>
                <samples>16</samples>
                <resolution>1</resolution>
                <min_angle>-0.261799</min_angle>
                <max_angle>0.261799</max_angle>
              </vertical>
            </scan>
            <range>
              <min>0.5</min>
              <max>50.0</max>
              <resolution>0.02</resolution>
            </range>
            <noise>
              <type>gaussian</type>
              <mean>0</mean>
              <stddev>0.02</stddev>
            </noise>
          </lidar>
          <always_on>1</always_on>
          <visualize>true</visualize>
        </sensor>
      </link>

      <!-- ====== LiDAR 外观 (圆柱体在顶上) ====== -->
      <link name="lidar_vis">
        <pose>0 0 0.3 0 0 0</pose>
        <visual name="v"><geometry><cylinder><radius>0.1</radius><length>0.08</length></cylinder></geometry>
          <material><ambient>0.1 0.1 0.1</ambient><diffuse>0.15 0.15 0.15</diffuse></material>
        </visual>
        <inertial><mass>0.01</mass><inertia><ixx>0.0001</ixx><iyy>0.0001</iyy><izz>0.0001</izz></inertia></inertial>
      </link>
      <joint name="lidar_vis_joint" type="fixed">
        <parent>chassis</parent><child>lidar_vis</child>
      </joint>

      <!-- ====== IMU 外观标记 (小蓝块) ====== -->
      <link name="imu_vis">
        <pose>0.2 0 -0.05 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.08 0.06 0.04</size></box></geometry>
          <material><ambient>0.1 0.3 0.9</ambient><diffuse>0.1 0.4 1.0</diffuse></material>
        </visual>
        <inertial><mass>0.001</mass><inertia><ixx>0.00001</ixx><iyy>0.00001</iyy><izz>0.00001</izz></inertia></inertial>
      </link>
      <joint name="imu_vis_joint" type="fixed">
        <parent>chassis</parent><child>imu_vis</child>
      </joint>

      <!-- ====== 差速驱动 ====== -->
      <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
        <left_joint>left_wheel_joint</left_joint>
        <right_joint>right_wheel_joint</right_joint>
        <wheel_separation>0.6</wheel_separation>
        <wheel_radius>0.2</wheel_radius>
        <odom_publish_frequency>50</odom_publish_frequency>
        <topic>/cmd_vel</topic>
      </plugin>

      <!-- ====== 左轮 ====== -->
      <link name="left_wheel">
        <pose>0 -0.3 -0.2 0 0 0</pose>
        <inertial><mass>0.5</mass><inertia><ixx>0.005</ixx><iyy>0.005</iyy><izz>0.005</izz></inertia></inertial>
        <collision name="c"><geometry><cylinder><radius>0.2</radius><length>0.06</length></cylinder></geometry>
          <surface><friction><ode><mu>10.0</mu><mu2>10.0</mu2></ode></friction></surface>
        </collision>
        <visual name="v"><geometry><cylinder><radius>0.2</radius><length>0.06</length></cylinder></geometry>
          <material><ambient>0.15 0.15 0.15</ambient><diffuse>0.2 0.2 0.2</diffuse></material>
        </visual>
      </link>
      <joint name="left_wheel_joint" type="revolute">
        <parent>chassis</parent><child>left_wheel</child>
        <axis><xyz>0 1 0</xyz></axis>
      </joint>

      <!-- ====== 右轮 ====== -->
      <link name="right_wheel">
        <pose>0 0.3 -0.2 0 0 0</pose>
        <inertial><mass>0.5</mass><inertia><ixx>0.005</ixx><iyy>0.005</iyy><izz>0.005</izz></inertia></inertial>
        <collision name="c"><geometry><cylinder><radius>0.2</radius><length>0.06</length></cylinder></geometry>
          <surface><friction><ode><mu>10.0</mu><mu2>10.0</mu2></ode></friction></surface>
        </collision>
        <visual name="v"><geometry><cylinder><radius>0.2</radius><length>0.06</length></cylinder></geometry>
          <material><ambient>0.15 0.15 0.15</ambient><diffuse>0.2 0.2 0.2</diffuse></material>
        </visual>
      </link>
      <joint name="right_wheel_joint" type="revolute">
        <parent>chassis</parent><child>right_wheel</child>
        <axis><xyz>0 1 0</xyz></axis>
      </joint>

      <!-- ====== 前支撑轮 (万向轮) ====== -->
      <link name="caster">
        <pose>0.35 0 -0.25 0 0 0</pose>
        <collision name="c"><geometry><sphere><radius>0.06</radius></sphere></geometry>
          <surface><friction><ode><mu>0.01</mu><mu2>0.01</mu2></ode></friction></surface>
        </collision>
        <visual name="v"><geometry><sphere><radius>0.06</radius></sphere></geometry>
          <material><ambient>0.1 0.1 0.1</ambient><diffuse>0.15 0.15 0.15</diffuse></material>
        </visual>
        <inertial><mass>0.01</mass><inertia><ixx>0.0001</ixx><iyy>0.0001</iyy><izz>0.0001</izz></inertia></inertial>
      </link>
      <joint name="caster_joint" type="ball">
        <parent>chassis</parent><child>caster</child>
      </joint>
    </model>

  </world>
</sdf>
