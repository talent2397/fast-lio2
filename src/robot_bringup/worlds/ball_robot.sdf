<sdf version="1.6">
  <world name="factory_open">
    <physics name="1ms" type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>
    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-imu-system" name="gz::sim::systems::Imu"/>
    <gravity>0 0 -9.81</gravity>
    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows><pose>0 0 15 0 0 0</pose>
      <diffuse>0.9 0.9 0.9</diffuse><direction>-0.4 0.2 -0.9</direction>
    </light>
    <model name="ground"><static>true</static>
      <link name="l"><collision name="c"><geometry><box><size>60 60 0.1</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>60 60 0.1</size></box></geometry>
          <material><ambient>0.5 0.5 0.5</ambient><diffuse>0.65 0.65 0.65</diffuse></material></visual></link></model>

<!-- ================================================================
     布局: 30×30 围墙封闭 | 十字主走廊 | 四个开放房间区
================================================================ -->

<!-- ====== 外围围墙 ====== -->
<model name="wall_n"><static>true</static><pose>0 15 2.5 0 0 0</pose>
  <link name="l"><collision name="c"><geometry><box><size>30 0.4 5</size></box></geometry></collision>
    <visual name="v"><geometry><box><size>30 0.4 5</size></box></geometry>
      <material><ambient>0.7 0.35 0.25</ambient><diffuse>0.75 0.4 0.3</diffuse></material></visual></link></model>
<model name="wall_s"><static>true</static><pose>0 -15 2.5 0 0 0</pose>
