#!/usr/bin/env python3
"""
全自动探索导航 — v10: 直接读取原始LiDAR点云做人工势场避障 (CoNi-OA启发)

根治碰撞:
  订阅 /robot/lidar (Gazebo原始点云, robot/lidar_link帧, 360°×16线)
  → 每帧3600+点 → 向量化投影到2D → 按角度分桶取最近点
  → 每点(d,θ)产生排斥力 -k/d²
  → 目标方向产生吸引力
  → 合力→cmd_vel (无阈值, 纯反应式)

边界探索:
  /map → 卷积找前沿 → 聚类 → 增益/距离/朝向评分 → A* → 势场驱动
"""
import math, time, heapq, numpy as np
from collections import deque
from scipy import ndimage
import rclpy

FULL_CIRCLE = 2 * math.pi; SPIN_TIMEOUT = 40.0
MAX_V = 0.8; MAX_W = 1.5; GOAL_DIST = 2.0; SPIN_SPD = 0.8

# 势场参数 (借鉴 CoNi-OA)
K_REP = 1.5; K_ATT = 0.8; K_ANG = 2.0
D_SAFE = 2.5; D_BACK = 0.5

# 前沿评分权重
W_GAIN = 2.0; W_DIST = 2.0; W_TURN = 1.5

from rclpy.node import Node
from rclpy.qos import qos_profile_sensor_data
from geometry_msgs.msg import Twist, PoseStamped
from nav_msgs.msg import Odometry, OccupancyGrid
from sensor_msgs.msg import LaserScan, PointCloud2
from vision_msgs.msg import Detection2DArray

# 从 raw LiDAR 点云直接生成 2D scan-like 距离数组
def _cloud_to_scan_ranges(cloud_msg):
    """将单个PointCloud2帧转为720个角度桶的最近距离数组。
       点云在 robot/lidar_link 帧 (lidar传感器帧),
       直接投影到2D平面 (忽略z), 无需TF变换。
       返回 (ranges:numpy array size 720, num_valid:int)"""
    n_rays = 720
    angle_inc = 2.0 * math.pi / n_rays
    ranges = np.full(n_rays, np.inf, dtype=np.float32)

    try:
        # 结构化读取前12字节: x, y, z (float32 each)
        pt_step = cloud_msg.point_step
        pad = pt_step - 12
        if pad < 0: pad = 0
        dt = np.dtype([('x', np.float32), ('y', np.float32), ('z', np.float32),
                        ('_pad', f'V{pad}')])
        arr = np.frombuffer(cloud_msg.data, dtype=dt, count=cloud_msg.width)
    except Exception:
        return np.full(n_rays, np.inf, dtype=np.float32), 0

    x = arr['x'].astype(np.float64)
    y = arr['y'].astype(np.float64)
    z = arr['z'].astype(np.float64)

    # 高度过滤: 只取 0.05~2.0m (LiDAR在0.40m高处, 忽略地面和天花板)
    h_mask = (np.abs(z) > 0.05) & (np.abs(z) < 2.0)
    if np.count_nonzero(h_mask) < 10:
        return ranges, 0
    x, y = x[h_mask], y[h_mask]

    # 2D距离 (lidar在robot/lidar_link, 原点即传感器)
    dists = np.sqrt(x*x + y*y)
    d_mask = (dists > 0.3) & (dists < 30.0)
    if np.count_nonzero(d_mask) < 5:
        return ranges, 0
    x, y, dists = x[d_mask], y[d_mask], dists[d_mask]

    # 角度分桶
    angles = np.arctan2(y, x)
    indices = np.clip(((angles + math.pi) / angle_inc).astype(np.int32), 0, n_rays-1)

    # 逐桶取最近点
    order = np.argsort(indices)
    idx_sorted = indices[order]
    dist_sorted = dists[order]
    i = 0
    while i < len(idx_sorted):
        bid = idx_sorted[i]
        j = i + 1
        while j < len(idx_sorted) and idx_sorted[j] == bid:
            j += 1
        ranges[bid] = np.min(dist_sorted[i:j])
        i = j

    n_valid = np.count_nonzero(~np.isinf(ranges))
    return ranges, n_valid


class AutoExplorer(Node):
    def __init__(self):
        super().__init__('auto_explorer')
        self.state = 'SPIN_WAIT'
        self.pose = None; self.yaw = 0.0
        self.map = None; self.map_info = None
        self.scan_ranges = None      # 从 raw LiDAR 直接生成的 ranges (720 floats)
        self._scan_valid = 0          # 有效 ray 数量
        self.fusion_tgt = None; self.last_det = None
        self.path = []; self._path_target = None
        self._spin = 0.0; self._py = None
        self._lr = 0.0; self._cnt = 0
        self._vst = set()
        self._last_goal = None
        self._stuck = 0.0; self._lp = None
        self._last_ft = 0.0
        self._spin_log = 0.0; self._spin_start = time.time()
        self._no_ft_count = 0
        self._log_t = 0.0
        self._fplan_t = 0.0; self._los_fail_t = 0.0
        self._diag_t = 0.0; self._proc_n = 0

        # 订阅原始 LiDAR (Gazebo, robot/lidar_link 帧, ~10Hz)
        self.create_subscription(
            PointCloud2, '/robot/lidar', self._raw_lidar, qos_profile_sensor_data)
        # 建图用
        self.create_subscription(Odometry, '/robot/odom', self._odom, 10)
        self.create_subscription(OccupancyGrid, '/map', self._map, 10)
        self.create_subscription(Detection2DArray, '/robot/detections', self._det, 10)
        self.create_subscription(PoseStamped, '/robot/target_pose', self._tgt, 10)
        self.pub = self.create_publisher(Twist, '/robot/cmd_vel', 10)
        self.timer = self.create_timer(0.05, self._run)
        self.get_logger().info('AutoExplorer v10 (raw LiDAR APF) 就绪')

    def _raw_lidar(self, m):
        """直接从原始LiDAR点云生成scan ranges"""
        ranges, n_valid = _cloud_to_scan_ranges(m)
        self.scan_ranges = ranges
        self._scan_valid = n_valid
        self._proc_n += 1
        if self._proc_n % 50 == 0:
            self.get_logger().info(
                f'[LIDAR] {m.width}pts → {n_valid}/{len(ranges)} rays '
                f'(cloud rate ~{self._proc_n*0.1:.0f}Hz)')

    def _odom(self, m):
        p = m.pose.pose.position
        if self._lp:
            moved = math.hypot(p.x-self._lp[0], p.y-self._lp[1])
            self._stuck += 0.05 if moved < 0.01 else -min(self._stuck, 0.05)
        self._lp = (p.x, p.y); self.pose = p
        q = m.pose.pose.orientation
        y = math.atan2(2*(q.w*q.z+q.x*q.y), 1-2*(q.y*q.y+q.z*q.z))
        if self._py is not None:
            d = y-self._py; self._spin+=abs(math.atan2(math.sin(d),math.cos(d)))
        self._py = y; self.yaw = y

    def _map(self, m):
        self.map_info = m.info
        self.map = np.array(m.data, dtype=np.int8).reshape(m.info.height, m.info.width)

    def _tgt(self, m): self.fusion_tgt = m
    def _det(self, m):
        if m.detections: self.last_det = self.get_clock().now()
    def _map_ready(self):
        if self.map is None: return False
        return int(np.count_nonzero(self.map==0)) > self.map.size*0.01

    # ═══════════════════════════════════════════════════════════
    # 人工势场 (CoNi-OA 启发)
    # ═══════════════════════════════════════════════════════════
    def _potential_field(self, goal_wx, goal_wy):
        """
        对 self.scan_ranges (来自 raw LiDAR) 中的每个有效ray:
          点位置 p = (d·cosθ, d·sinθ)
          排斥力 F_rep = -k(d) · unit(p)  其中 k(d) ∝ 1/d²
        吸引力 F_att 朝向目标
        合力 → (v, ω)
        """
        if self.scan_ranges is None or self._scan_valid < 5:
            return 0.0, 0.0

        n = len(self.scan_ranges)
        fx, fy = 0.0, 0.0

        # ── 排斥力 ──
        for i in range(n):
            d = self.scan_ranges[i]
            if not (0.3 < d < 30): continue
            if math.isinf(d): continue

            angle = -math.pi + i * (2.0 * math.pi / n)
            cos_a, sin_a = math.cos(angle), math.sin(angle)

            if d < D_BACK:
                k = K_REP * 5.0
            elif d < D_SAFE:
                k = K_REP * (D_SAFE / d) ** 2
            else:
                k = K_REP * (D_SAFE / d) * 0.2

            fx -= k * cos_a
            fy -= k * sin_a

        # ── 吸引力 ──
        if goal_wx is not None and goal_wy is not None:
            dx = goal_wx - self.pose.x
            dy = goal_wy - self.pose.y
            dist = math.hypot(dx, dy)
            if dist > 0.1:
                att_k = min(K_ATT, K_ATT * dist / 3.0)
                fx += att_k * dx / dist
                fy += att_k * dy / dist

        force_mag = math.hypot(fx, fy)
        if force_mag < 0.02:
            return 0.0, 0.0

        force_angle = math.atan2(fy, fx)
        v = min(MAX_V, force_mag * 0.6)

        err = force_angle - self.yaw
        err = math.atan2(math.sin(err), math.cos(err))
        w = max(-MAX_W, min(MAX_W, K_ANG * err))

        if abs(err) > 0.8:
            v *= 0.2
            w = max(-MAX_W, min(MAX_W, 1.2 * (1 if err > 0 else -1)))

        return v, w

    # ═══════════════════════════════════════════════════════════
    # A* / 前沿 / LOS (和 v8/v9 一样)
    # ═══════════════════════════════════════════════════════════
    def _astar(self, sx, sy, gx, gy):
        if self.map is None or self.map_info is None: return None
        mi=self.map_info; r=mi.resolution; ox=mi.origin.position.x; oy=mi.origin.position.y
        H,W=self.map.shape; step=max(1,int(0.5/r))
        def w2i(x,y): return (int((x-ox)/r), int((y-oy)/r))
        def i2w(ix,iy): return (ix*r+ox+r/2, iy*r+oy+r/2)
        six,siy=w2i(sx,sy); gix,giy=w2i(gx,gy)
        if not(0<=six<W and 0<=siy<H and 0<=gix<W and 0<=giy<H): return None
        d8=[(-step,0),(step,0),(0,-step),(0,step),(-step,-step),(-step,step),(step,-step),(step,step)]
        op=[(0,0,six,siy)]; cf={}; gs={(six,siy):0}
        while op:
            _,cost,cx,cy=heapq.heappop(op)
            if max(abs(cx-gix),abs(cy-giy))<=step:
                path=[(gix,giy)]; cur=(cx,cy)
                while cur in cf: path.append(cur); cur=cf[cur]
                pts=[i2w(x,y) for x,y in reversed(path)]
                if len(pts)>4: pts=[pts[0]]+pts[1:-1:3]+[pts[-1]]
                return pts
            for dx,dy in d8:
                nx,ny=cx+dx,cy+dy
                if not(0<=nx<W and 0<=ny<H): continue
                if self.map[ny,nx]>50: continue
                nc=cost+math.hypot(dx,dy)*r
                if (nx,ny) not in gs or nc<gs[(nx,ny)]:
                    gs[(nx,ny)]=nc; f=nc+math.hypot(nx-gix,ny-giy)*r
                    heapq.heappush(op,(f,nc,nx,ny)); cf[(nx,ny)]=(cx,cy)
        return None

    def _frontier_clusters(self):
        if self.map is None: return []
        h,w=self.map.shape; r=self.map_info.resolution
        ox=self.map_info.origin.position.x; oy=self.map_info.origin.position.y
        free=self.map==0
        if np.count_nonzero(free)<100: return []
        unknown=self.map==-1
        kernel=np.array([[0,1,0],[1,0,1],[0,1,0]],dtype=np.int8)
        nu=ndimage.convolve(unknown.astype(np.int8),kernel,mode='constant',cval=0)
        fm=free&(nu>0); f_rc=np.argwhere(fm)
        if len(f_rc)<10: return []
        f=[(rr,cc) for i,(rr,cc) in enumerate(f_rc) if i%4==0]
        if len(f)<5: f=[(rr,cc) for rr,cc in f_rc[:5000]]
        fs=set(f); clusters=[]; vis=set()
        for cell in f:
            if cell in vis: continue
            cl=[]; q=deque([cell]); vis.add(cell)
            while q:
                rr,cc=q.popleft(); cl.append((rr,cc))
                for dr in [-2,-1,0,1,2]:
                    for dc in [-2,-1,0,1,2]:
                        nr,nc=rr+dr,cc+dc
                        if (nr,nc) in fs and (nr,nc) not in vis:
                            vis.add((nr,nc)); q.append((nr,nc))
            if len(cl)>=8: clusters.append(cl)
        result=[]
        for cl in clusters:
            mr=sum(c[0] for c in cl)/len(cl); mc=sum(c[1] for c in cl)/len(cl)
            result.append((mc*r+ox+r/2, mr*r+oy+r/2, len(cl)))
        return result

    def _score_frontier(self, wx, wy, size):
        dx=wx-self.pose.x; dy=wy-self.pose.y; dist=math.hypot(dx,dy)
        target_heading=math.atan2(dy,dx)
        heading_err=abs(math.atan2(math.sin(target_heading-self.yaw),
                                    math.cos(target_heading-self.yaw)))
        gain=math.log1p(size)/math.log1p(100)
        return W_GAIN*gain - W_DIST*min(dist/15.0,1.0) - W_TURN*heading_err/math.pi

    def _los_lookahead(self):
        if not self.path or self.map is None: return None
        mi=self.map_info; r=mi.resolution
        ox=mi.origin.position.x; oy=mi.origin.position.y
        px,py=self.pose.x,self.pose.y
        for i in range(len(self.path)-1,-1,-1):
            wx,wy=self.path[i]; dist=math.hypot(wx-px,wy-py)
            if dist<0.8 and i>0: continue
            if dist>4.0: continue
            if not self._line_collision(px,py,wx,wy): return (wx,wy)
        for i in range(len(self.path)):
            wx,wy=self.path[i]
            if not self._line_collision(px,py,wx,wy): return (wx,wy)
        return None

    def _line_collision(self, x1,y1,x2,y2):
        if self.map is None or self.map_info is None: return True
        mi=self.map_info; r=mi.resolution
        ox=mi.origin.position.x; oy=mi.origin.position.y
        H,W=self.map.shape
        ix1,iy1=int((x1-ox)/r),int((y1-oy)/r); ix2,iy2=int((x2-ox)/r),int((y2-oy)/r)
        dx,dy=abs(ix2-ix1),abs(iy2-iy1)
        sx=1 if ix2>ix1 else -1; sy=1 if iy2>iy1 else -1
        err=dx-dy; x,y=ix1,iy1
        for _ in range(max(dx,dy)+1):
            if not(0<=x<W and 0<=y<H): return True
            if self.map[y,x]>50: return True
            if x==ix2 and y==iy2: break
            e2=2*err
            if e2>-dy: err-=dy; x+=sx
            if e2<dx: err+=dx; y+=sy
        return False

    # ═══════════════════════════════════════
    # 主循环
    # ═══════════════════════════════════════
    def _run(self):
        if self.pose is None: return
        c = Twist(); now = time.time()

        # diag
        if now - self._diag_t > 2.0 and self.scan_ranges is not None:
            self._diag_t = now
            n = len(self.scan_ranges)
            mid = n // 2; cone = n // 12
            fv = sorted([self.scan_ranges[i%n] for i in range(mid-cone, mid+cone)
                        if 0.3 < self.scan_ranges[i%n] < 30])
            self.get_logger().info(
                f'[SCAN] F_min={fv[0] if fv else "---"}m '
                f'top3={[f"{x:.1f}" for x in fv[max(0,len(fv)-3):]]} '
                f'valid={self._scan_valid}/{n}')

        # ── SPIN_WAIT ──
        if self.state == 'SPIN_WAIT':
            spun = self._spin > FULL_CIRCLE * 1.2
            map_ok = self._map_ready()
            tmout = (now - self._spin_start) > SPIN_TIMEOUT
            if (spun and map_ok) or (spun and tmout):
                self._stuck = 0.0; self._no_ft_count = 0; self.state = 'EXPLORE'
                free = np.count_nonzero(self.map == 0) if self.map is not None else 0
                rsn = 'map_ok' if map_ok else f'timeout({now-self._spin_start:.0f}s)'
                self.get_logger().info(f'→EXPLORE ({rsn}, spin={self._spin:.1f}rad, free={free})')
                self.pub.publish(Twist()); return
            if now - self._spin_log > 2.0:
                self._spin_log = now
                fn = np.count_nonzero(self.map == 0) if self.map is not None else 0
                self.get_logger().info(f'SPIN_WAIT: {self._spin:.1f}/{FULL_CIRCLE*1.2:.1f}rad free={fn}')
            c.angular.z = SPIN_SPD; self.pub.publish(c); return

        # ── 目标切换 ──
        if self.last_det is not None:
            dt = (self.get_clock().now() - self.last_det).nanoseconds / 1e9
            if self.state != 'CHASE' and dt < 1.5:
                self.state = 'CHASE'; self.path = []; self._path_target = None
            elif self.state == 'CHASE' and dt > 4.0:
                self.state = 'EXPLORE'; self.path = []; self._path_target = None

        # ── CHASE ──
        if self.state == 'CHASE':
            if self.fusion_tgt is None:
                v, w = self._potential_field(None, None)
                c.linear.x = max(v, 0.1); c.angular.z = 0.4; self.pub.publish(c); return
            tp = self.fusion_tgt.pose.position
            d = math.hypot(tp.x-self.pose.x, tp.y-self.pose.y)
            if d < GOAL_DIST:
                self.state = 'REACHED'; self.pub.publish(Twist())
                self.get_logger().info(f'到达! {d:.1f}m'); return
            ang_tgt = math.atan2(tp.y-self.pose.y, tp.x-self.pose.x)
            gx = tp.x - GOAL_DIST*math.cos(ang_tgt)
            gy = tp.y - GOAL_DIST*math.sin(ang_tgt)
            v, w = self._potential_field(gx, gy)
            c.linear.x = v; c.angular.z = w; self.pub.publish(c); return

        # ── REACHED ──
        if self.state == 'REACHED':
            if now - self._log_t > 5.0: self._log_t = now; self.get_logger().info('任务完成')
            self.pub.publish(Twist()); return

        # ── EXPLORE ──
        if self.path and self._path_target:
            los = self._los_lookahead()
            gx_tgt, gy_tgt = los if los else self._path_target
            v, w = self._potential_field(gx_tgt, gy_tgt)
            c.linear.x = v; c.angular.z = w
            dtg = math.hypot(self._path_target[0]-self.pose.x, self._path_target[1]-self.pose.y)
            if dtg < 1.0 and (now - self._fplan_t) > 2.0:
                self.path = []; self._path_target = None
                if self._last_goal: self._vst.add(self._last_goal)
                self.get_logger().info(f'到达前沿 #{self._cnt}'); self._stuck = 0.0
            self.pub.publish(c); return

        los_recent = (now - self._los_fail_t) < 1.0
        need_replan = ((self._path_target is None and not los_recent) or
                       now - self._fplan_t > 15.0)
        if now - self._last_ft > 0.5 and need_replan:
            self._last_ft = now
            clusters = self._frontier_clusters()
            if clusters:
                scored = []
                for wx, wy, size in clusters:
                    mk = (round(wx/3), round(wy/3))
                    if mk in self._vst: continue
                    scored.append((self._score_frontier(wx, wy, size), wx, wy, mk, size))
                if scored:
                    scored.sort(reverse=True)
                    _, gx, gy, mk, size = scored[0]
                    self._last_goal = mk
                    rw = self._astar(self.pose.x, self.pose.y, gx, gy)
                    if rw:
                        self.path = rw; self._path_target = (gx, gy)
                        self._cnt += 1; self._stuck = 0.0
                        self._no_ft_count = 0
                        self._fplan_t = now; self._los_fail_t = 0.0
                        d = math.hypot(gx-self.pose.x, gy-self.pose.y)
                        self.get_logger().info(f'→({gx:.1f},{gy:.1f}) d={d:.1f}m sz={size} #{self._cnt}')
                        self.pub.publish(c); return
                self._vst.clear()
            else:
                self._no_ft_count += 1

        if self._stuck > 5.0:
            self.get_logger().warn(f'stuck={self._stuck:.1f}s 逃脱')
            c.angular.z = 1.2
            self._stuck = 0.0; self.path = []; self._vst.clear(); self._no_ft_count = 0
            self.pub.publish(c); return

        if self._no_ft_count > 10:
            if now - self._log_t > 3.0:
                self._log_t = now
                self.get_logger().info(f'无前沿x{self._no_ft_count}, 势场→开阔区')
            if self.scan_ranges is not None and self._scan_valid > 5:
                n = len(self.scan_ranges)
                best_i, best_d = 0, 0
                for i in range(0, n, 5):
                    d = self.scan_ranges[i]
                    if 0.5 < d < 30 and not math.isinf(d) and d > best_d:
                        best_d = d; best_i = i
                best_angle = self.yaw + (-math.pi + best_i * 2*math.pi/n) if best_d > 0 else self.yaw
                gx_tgt = self.pose.x + 3.0 * math.cos(best_angle)
                gy_tgt = self.pose.y + 3.0 * math.sin(best_angle)
            else:
                gx_tgt = self.pose.x + math.cos(self.yaw)
                gy_tgt = self.pose.y + math.sin(self.yaw)
            v, w = self._potential_field(gx_tgt, gy_tgt)
            c.linear.x = v; c.angular.z = w
            self.pub.publish(c); return

        gx_tgt = self.pose.x + 2.0 * math.cos(self.yaw)
        gy_tgt = self.pose.y + 2.0 * math.sin(self.yaw)
        v, w = self._potential_field(gx_tgt, gy_tgt)
        c.linear.x = v; c.angular.z = w
        self.pub.publish(c)

def main(): rclpy.init(); rclpy.spin(AutoExplorer())
if __name__ == '__main__': main()
