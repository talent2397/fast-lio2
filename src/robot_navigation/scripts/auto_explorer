#!/usr/bin/env python3
"""
全自动探索导航 — v22: 震荡检测+前沿重规划防死循环+定期环视+HSV检测支持
  v18基础: 持久化追踪+障碍绕行+引力增强
  v21修复: 到达前沿3x3vst标记 + 全黑名不清vst→push + push加速
  v22修复: 前沿重规划计数(3次→vst) + 震荡位置检测 + 定期环视找球
           + push方向多样性 + vst软清理(50%) + YOLO置信度0.3+HSV启用
"""
import math, time, heapq, numpy as np
from collections import deque
from scipy import ndimage
import rclpy

FULL_CIRCLE = 2*math.pi; SPIN_TIMEOUT = 20.0
MAX_V = 1.5; MAX_W = 2.0; GOAL_DIST = 1.0; SPIN_SPD = 1.2

K_REP = 1.0;   K_ATT = 1.5;   K_ANG = 1.8
D_SAFE = 2.0;  D_BACK = 1.0
W_GAIN = 2.0;  W_DIST = 0.1;  W_TURN = 1.5   # v21: W_DIST降到0.1 更偏好远处前沿

# 多层安全
PRE_BRAKE_DIST = 1.1    # 预减速(缩短,减少龟爬)
HARD_BRAKE_DIST = 0.8   # 硬刹车
EMERGENCY_DIST = 0.4    # 紧急
SPIN_TRAP_LIMIT = 2.5   # 被困旋转>2.5s强制直行
LOS_MAX = 8.0            # LOS前瞻距离(原5m)
FT_DIST_DENOM = 45.0     # 前沿距离归一化分母(原20, 适配30x30m)

from rclpy.node import Node
from rclpy.qos import qos_profile_sensor_data
from geometry_msgs.msg import Twist, PoseStamped
from nav_msgs.msg import Odometry, OccupancyGrid
from sensor_msgs.msg import LaserScan
from vision_msgs.msg import Detection2DArray


class AutoExplorer(Node):
    def __init__(self):
        super().__init__('auto_explorer')
        self.state = 'SPIN_WAIT'
        self.pose = None; self.yaw = 0.0
        self.map = None; self.map_info = None
        self.scan_ranges = None; self._scan_valid = 0
        self.fusion_tgt = None; self.last_det = None
        self.path = []; self._path_target = None
        self._spin = 0.0; self._py = None
        self._lr = 0.0; self._cnt = 0; self._vst = set()
        self._last_goal = None
        self._stuck = 0.0; self._lp = None
        self._last_ft = 0.0
        self._spin_log = 0.0; self._spin_start = time.time()
        self._no_ft_count = 0; self._log_t = 0.0
        self._fplan_t = 0.0; self._los_fail_t = 0.0
        self._diag_t = 0.0
        self._odom_n = 0
        self._back_t = 0.0; self._back_dir = 0.8; self._back_dir_locked = False
        self._post_brake_t = 0.0
        self._brake_count = 0
        self._stuck_escalate = 0
        self._bias_angle = None
        self._spin_scan_t = 0.0
        self._spin_scan_total = 0.0
        self._scan_push_t = 0.0
        self._scan_push_dir = 0.0
        self._push_tgt = None
        self._push_tgt_t = 0.0
        self._force_straight_t = 0.0
        self._force_straight_dir = 0.0
        self._thrash_w = []
        self._thrash_t = 0.0
        self._last_yaw = None
        self._front_min = 99.0       # v15: 宽锥前向最小距离(硬刹车用)
        self._front_narrow = 99.0    # v15.1: 窄锥前向最小距离(预减速用)
        self._spin_trap_t = 0.0      # v15.1: 旋转陷阱计时
        self._stuck_straight_pending = 0.0  # v16: stuck退避后待直行时间
        self._post_brake_full = 0.0         # v17: 记录post_brake初始时长
        self._acquire_start = 0.0          # v17.1: ACQUIRE开始时间
        self._acquire_cooldown_t = 0.0     # v17.2: ACQUIRE冷却计时(5s)
        self._chase_start = 0.0            # v17.3: CHASE开始时间, 防冷启动误触发REACHED
        self._fusion_tgt_time = 0.0        # v18: fusion_tgt最后更新时间(用于保鲜检查)
        self._chase_lost_since = 0.0       # v18: CHASE丢失检测的计时起点
        self._chase_plan = []              # v18: CHASE障碍物绕行路径
        self._chase_plan_target = None     # v18: CHASE路径目标点
        self._chase_replan_needed = False  # v19: 到达路径终点立即重规划
        self._stuck_check_t = 0.0          # v20: stuck时间窗口检测起点
        self._stuck_check_pos = None       # v20: stuck检测的参考位置
        self._frontier_attempts = {}       # v22: 前沿重规划计数 {(gx,gy): count}
        self._recent_positions = deque(maxlen=30)  # v22: 近期位置记录(震荡检测)
        self._target_scan_t = 0.0          # v22: 定期环视定时器
        self._recent_push_dirs = deque(maxlen=5)   # v22: 近期push方向(去重)

        from rclpy.qos import QoSProfile, DurabilityPolicy, ReliabilityPolicy
        _map_qos = QoSProfile(depth=10, durability=DurabilityPolicy.TRANSIENT_LOCAL, reliability=ReliabilityPolicy.RELIABLE)
        self.create_subscription(LaserScan, '/scan', self._scan, qos_profile_sensor_data)
        self.create_subscription(Odometry, '/robot/odom', self._odom, 10)
        self.create_subscription(OccupancyGrid, '/map', self._map, _map_qos)
        self.create_subscription(Detection2DArray, '/robot/detections', self._det, 10)
        self.create_subscription(PoseStamped, '/robot/target_pose', self._tgt, 10)
        self.pub = self.create_publisher(Twist, '/robot/cmd_vel', 10)
        self.timer = self.create_timer(0.05, self._run)
        self.get_logger().info('AutoExplorer v22 (oscillation fix+target scan+frontier counter) 就绪')

    def _scan(self, m):
        self.scan_ranges = m.ranges
        self._scan_valid = int(np.count_nonzero(
            [True for v in m.ranges if 0.5 < v < 30 and not math.isinf(v)]))

    def _odom(self, m):
        self._odom_n += 1
        p = m.pose.pose.position
        if self._lp:
            # v20: stuck时间窗口检测 (原per-odom导致FAST-LIO高频误判)
            # 每~1秒累积检查: 1秒内总位移<0.15m → 才算stuck+1.0
            if self._stuck_check_t <= 0:
                self._stuck_check_t = time.time()
                self._stuck_check_pos = self._lp
            elapsed = time.time() - self._stuck_check_t
            if elapsed > 1.0:
                total_moved = math.hypot(p.x-self._stuck_check_pos[0],
                                         p.y-self._stuck_check_pos[1])
                if total_moved < 0.15:
                    self._stuck += 1.0    # 过去1秒几乎没动
                else:
                    self._stuck = max(0.0, self._stuck - 0.5)  # 有运动→减stuck
                self._stuck_check_t = time.time()
                self._stuck_check_pos = (p.x, p.y)
        self._lp = (p.x, p.y); self.pose = p
        q = m.pose.pose.orientation
        y = math.atan2(2*(q.w*q.z+q.x*q.y), 1-2*(q.y*q.y+q.z*q.z))
        if self._py is not None: d=y-self._py; self._spin+=abs(math.atan2(math.sin(d),math.cos(d)))
        self._py = y; self.yaw = y

    def _map(self, m):
        self.map_info = m.info
        self.map = np.array(m.data, dtype=np.int8).reshape(m.info.height, m.info.width)
    def _tgt(self, m):
        self.fusion_tgt = m
        self._fusion_tgt_time = time.time()
    def _det(self, m):
        if m.detections: self.last_det = self.get_clock().now()
    def _map_ready(self):
        if self.map is None: return False
        return int(np.count_nonzero(self.map==0)) > self.map.size*0.05

    # ═══ 扫描前向最小距离 (每tick更新) ═══
    def _update_front_min(self):
        self._front_min = 99.0; self._front_narrow = 99.0
        if self.scan_ranges is None or self._scan_valid < 5:
            return
        n = len(self.scan_ranges); mid = n//2
        # 宽锥(±45°): 用于硬刹车
        wide_cone = n//8
        # 窄锥(±20°): 用于预减速(只检测朝向方向)
        narrow_cone = n//18
        fv_wide = [self.scan_ranges[i%n] for i in range(mid-wide_cone, mid+wide_cone+1)
                   if 0.5 < self.scan_ranges[i%n] < 30 and not math.isinf(self.scan_ranges[i%n])]
        fv_narrow = [self.scan_ranges[i%n] for i in range(mid-narrow_cone, mid+narrow_cone+1)
                     if 0.5 < self.scan_ranges[i%n] < 30 and not math.isinf(self.scan_ranges[i%n])]
        if fv_wide: self._front_min = min(fv_wide)
        if fv_narrow: self._front_narrow = min(fv_narrow)

    # ═══ 多层安全: 窄锥预减速(精准) + 宽锥硬刹车(安全) ═══
    def _safety_check(self, c):
        """返回True表示已接管控制"""
        self._update_front_min()
        fm_wide = self._front_min        # ±45°: 硬刹车
        fm_narrow = self._front_narrow   # ±20°: 预减速

        # Layer 3: 紧急 (宽锥, 不可逆)
        if fm_wide < EMERGENCY_DIST:
            c.linear.x = -0.3; c.angular.z = 0.0
            self.get_logger().error(f'EMERGENCY! F={fm_wide:.2f}m', throttle_duration_sec=1.0)
            return True

        # Layer 2: 硬刹车 (宽锥)
        if fm_wide < HARD_BRAKE_DIST and self._back_t <= 0 and self._scan_valid >= 5:
            n = len(self.scan_ranges); mid = n//2; cone = n//8
            hits = sum(1 for i in range(mid-cone, mid+cone+1)
                      if 0.5 < self.scan_ranges[i%n] < HARD_BRAKE_DIST
                      and not math.isinf(self.scan_ranges[i%n]))
            if hits >= 3:
                if self.pose is not None:
                    mk = (round(self.pose.x/1.5), round(self.pose.y/1.5))
                    self._vst.add(mk)
                if not self._back_dir_locked:
                    self._brake_count += 1
                    q = n//4
                    l = min((v for v in [self.scan_ranges[i%n] for i in range(mid,mid+q)]
                            if 0.5<v<30), default=99.0)
                    r = min((v for v in [self.scan_ranges[i%n] for i in range(mid-q,mid)]
                            if 0.5<v<30), default=99.0)
                    self._back_dir = 1.0 if l > r else -1.0
                    self._back_dir_locked = True
                    loop = '(LOOP!)' if self._brake_count >= 2 else ''
                    self.get_logger().warn(f'HARD BRAKE! F={fm_wide:.2f}m #{self._brake_count} {loop}')
                self._back_t = 1.2; self.path = []; self._stuck = 0.0
                self._chase_plan = []; self._chase_plan_target = None  # v18: 刹车后重规划
                self._force_straight_t = 0.0
                c.linear.x = -0.5; c.angular.z = self._back_dir
                return True

        if self._back_dir_locked and fm_wide > 3.0:
            self._back_dir_locked = False; self._back_t = 0.0
            self._post_brake_t = 2.5
            self.get_logger().info('Brake released')

        # Layer 1: 预减速 (仅窄锥 — 只有朝向障碍时才限速)
        if fm_narrow < PRE_BRAKE_DIST:
            # 开阔环境: 预减速从0.35起(v17原0.25), 0.8m→0.35, 1.1m→0.5
            speed_limit = 0.35 + 0.15 * (fm_narrow - HARD_BRAKE_DIST) / (PRE_BRAKE_DIST - HARD_BRAKE_DIST)
            self._speed_limit = max(0.30, min(MAX_V, speed_limit))
        else:
            self._speed_limit = MAX_V
        return False

    # ═══ 势场: 排斥力截断防止门槛恐惧 ═══
    def _potential_field(self, goal_wx, goal_wy):
        if self.scan_ranges is None or self._scan_valid < 5:
            return 0.0, 0.0
        n = len(self.scan_ranges); fx, fy = 0.0, 0.0
        n_rep = 0  # v16: 统计排斥力贡献点
        step = max(1, n // 360)
        for i in range(0, n, step):
            d = self.scan_ranges[i]
            if not (0.5 < d < 30): continue
            if math.isinf(d): continue
            angle = -math.pi + i*(2.0*math.pi/n)
            rel_to_front = math.atan2(math.sin(angle), math.cos(angle))
            if abs(rel_to_front) > math.pi * 0.75:
                continue
            ca, sa = math.cos(angle), math.sin(angle)
            if d < D_BACK:       k = K_REP * 8.0
            elif d < D_SAFE:     k = K_REP * (D_SAFE/d)**2
            else:                k = K_REP * (D_SAFE/d) * 0.2
            # v16: 单点斥力截断, 防止近墙点产生天文数字级力
            k = min(k, 5.0)
            fx -= k*ca; fy -= k*sa
            n_rep += 1

        # v16: 总排斥力截断, 保证引力不会被完全淹没
        rep_mag = math.hypot(fx, fy)
        max_rep = 8.0  # 最大排斥合力
        if rep_mag > max_rep:
            fx *= max_rep / rep_mag
            fy *= max_rep / rep_mag

        cos_y, sin_y = math.cos(self.yaw), math.sin(self.yaw)
        fx_world = fx * cos_y - fy * sin_y
        fy_world = fx * sin_y + fy * cos_y

        if goal_wx is not None and goal_wy is not None:
            dx = goal_wx - self.pose.x; dy = goal_wy - self.pose.y
            dist = math.hypot(dx, dy)
            if dist > 0.1:
                att_k = min(K_ATT, K_ATT*dist/4.0)
                fx_world += att_k*dx/dist; fy_world += att_k*dy/dist

        fm = math.hypot(fx_world, fy_world)
        if fm < 0.02: return 0.0, 0.0
        f_ang = math.atan2(fy_world, fx_world)
        v = min(self._speed_limit, fm*0.7)
        err = f_ang - self.yaw; err = math.atan2(math.sin(err), math.cos(err))
        w = max(-MAX_W, min(MAX_W, K_ANG*err))
        if abs(err) > 0.8:
            v *= 0.15; w = max(-MAX_W, min(MAX_W, 1.2*(1 if err>0 else -1)))
        elif abs(err) < 0.2:
            v = max(v, 0.3)      # 小误差保底0.3m/s(v15:0.25)
        return v, w

    # ═══ CHASE专用势场: 更强引力+更弱斥力 (v18) ═══
    def _potential_field_chase(self, goal_wx, goal_wy):
        """CHASE模式: K_ATT=2.5(原1.5), max_rep=5.0(原8.0), 后半球斥力减半"""
        if self.scan_ranges is None or self._scan_valid < 5:
            return 0.0, 0.0
        n = len(self.scan_ranges); fx, fy = 0.0, 0.0
        step = max(1, n // 360)
        for i in range(0, n, step):
            d = self.scan_ranges[i]
            if not (0.5 < d < 30): continue
            if math.isinf(d): continue
            angle = -math.pi + i*(2.0*math.pi/n)
            rel_to_front = math.atan2(math.sin(angle), math.cos(angle))
            # 前半球±90°: 正常斥力; 后半球: 斥力减半 (更激进靠近目标)
            if abs(rel_to_front) > math.pi * 0.5:
                rear_factor = 0.3
            else:
                rear_factor = 1.0
            ca, sa = math.cos(angle), math.sin(angle)
            if d < D_BACK:       k = K_REP * 6.0 * rear_factor
            elif d < D_SAFE:     k = K_REP * (D_SAFE/d)**2 * rear_factor
            else:                k = K_REP * (D_SAFE/d) * 0.15 * rear_factor
            k = min(k, 4.0 * rear_factor)  # 单点斥力截断(比普通模式更低)
            fx -= k*ca; fy -= k*sa

        rep_mag = math.hypot(fx, fy)
        max_rep = 5.0  # v18: CHASE max_rep更低(普通8.0), 让引力主导
        if rep_mag > max_rep:
            fx *= max_rep / rep_mag
            fy *= max_rep / rep_mag

        cos_y, sin_y = math.cos(self.yaw), math.sin(self.yaw)
        fx_world = fx * cos_y - fy * sin_y
        fy_world = fx * sin_y + fy * cos_y

        if goal_wx is not None and goal_wy is not None:
            dx = goal_wx - self.pose.x; dy = goal_wy - self.pose.y
            dist = math.hypot(dx, dy)
            if dist > 0.1:
                att_k = min(K_ATT * 1.7, K_ATT * 1.7 * dist / 4.0)  # v18: 1.7x引力
                fx_world += att_k*dx/dist; fy_world += att_k*dy/dist

        fm = math.hypot(fx_world, fy_world)
        if fm < 0.02: return 0.0, 0.0
        f_ang = math.atan2(fy_world, fx_world)
        v = min(self._speed_limit, fm*0.8)  # v18: fm*0.8 (原0.7), 但尊重安全限速
        err = f_ang - self.yaw; err = math.atan2(math.sin(err), math.cos(err))
        w = max(-MAX_W, min(MAX_W, K_ANG*err))
        if abs(err) > 0.8:
            v *= 0.2; w = max(-MAX_W, min(MAX_W, 1.5*(1 if err>0 else -1)))
        elif abs(err) < 0.2:
            v = max(v, 0.35)      # v18: CHASE保底0.35m/s (原0.3)
        return v, w

    def _los_lookahead_chase(self):
        """CHASE路径LOS前瞻 (复用_chase_plan)"""
        if not self._chase_plan or self.map is None: return None
        mi = self.map_info; r = mi.resolution; ox = mi.origin.position.x; oy = mi.origin.position.y
        px, py = self.pose.x, self.pose.y
        for i in range(len(self._chase_plan)-1, -1, -1):
            wx, wy = self._chase_plan[i]; dist = math.hypot(wx-px, wy-py)
            if dist < 0.8 and i > 0: continue
            if dist > LOS_MAX: continue
            if not self._line_collision(px, py, wx, wy): return (wx, wy)
        for i in range(len(self._chase_plan)):
            wx, wy = self._chase_plan[i]
            if not self._line_collision(px, py, wx, wy): return (wx, wy)
        return None

    # ═══ 沿墙滑动绕行 (v19): A*失败时的fallback ═══
    def _tangent_bypass(self, gx, gy, tp):
        """沿障碍物边缘切线方向滑动, 偏置朝向球的方向"""
        if self.scan_ranges is None or self._scan_valid < 5:
            return gx, gy   # fallback to direct
        n = len(self.scan_ranges); mid = n//2
        # 球相对于机器人的角度
        ball_ang = math.atan2(tp.y - self.pose.y, tp.x - self.pose.x)
        ball_rel = math.atan2(math.sin(ball_ang - self.yaw),
                             math.cos(ball_ang - self.yaw))  # 机器人前方=0

        # 在前半球(±90°)找最开阔方向, 偏置朝向球的一侧
        best_score = -999.0; best_angle = 0.0
        for i in range(0, n, max(1, n//180)):
            d = self.scan_ranges[i]
            if not (0.5 < d < 30): d = 0.5
            if math.isinf(d): d = 0.5
            world_angle = -math.pi + i*2.0*math.pi/n
            rel_angle = math.atan2(math.sin(world_angle), math.cos(world_angle))
            # 只考虑前半球
            if abs(rel_angle) > math.pi * 0.65:
                continue
            # 评分: 距离 + 朝向球的偏置 (球在左边→偏好左边)
            toward_ball = -abs(rel_angle - ball_rel)  # 越接近球方向越好
            score = d * 0.6 + toward_ball * 3.0
            if score > best_score:
                best_score = score; best_angle = world_angle

        best_world = self.yaw + best_angle
        return (self.pose.x + 5.0*math.cos(best_world),
                self.pose.y + 5.0*math.sin(best_world))

    # ═══ A*/前沿/LOS ═══
    def _astar(self, sx, sy, gx, gy):
        if self.map is None or self.map_info is None: return None
        mi=self.map_info; r=mi.resolution; ox=mi.origin.position.x; oy=mi.origin.position.y
        H,W=self.map.shape; step=max(1,int(0.5/r))
        def w2i(x,y): return (int((x-ox)/r), int((y-oy)/r))
        def i2w(ix,iy): return (ix*r+ox+r/2, iy*r+oy+r/2)
        six,siy=w2i(sx,sy); gix,giy=w2i(gx,gy)
        if not(0<=six<W and 0<=siy<H and 0<=gix<W and 0<=giy<H): return None
        d8=[(-step,0),(step,0),(0,-step),(0,step),(-step,-step),(-step,step),(step,-step),(step,step)]
        op=[(0,0,six,siy)]; cf={}; gs={(six,siy):0}
        while op:
            _,cost,cx,cy=heapq.heappop(op)
            if max(abs(cx-gix),abs(cy-giy))<=step:
                path=[(gix,giy)]; cur=(cx,cy)
                while cur in cf: path.append(cur); cur=cf[cur]
                pts=[i2w(x,y) for x,y in reversed(path)]
                if len(pts)>4: pts=[pts[0]]+pts[1:-1:3]+[pts[-1]]
                return pts
            for dx,dy in d8:
                nx,ny=cx+dx,cy+dy
                if not(0<=nx<W and 0<=ny<H): continue
                if self.map[ny,nx]>50: continue
                nc=cost+math.hypot(dx,dy)*r
                if (nx,ny) not in gs or nc<gs[(nx,ny)]:
                    gs[(nx,ny)]=nc; f=nc+math.hypot(nx-gix,ny-giy)*r
                    heapq.heappush(op,(f,nc,nx,ny)); cf[(nx,ny)]=(cx,cy)
        return None
    def _frontier_clusters(self):
        if self.map is None: return []
        h,w=self.map.shape; r=self.map_info.resolution
        ox=self.map_info.origin.position.x; oy=self.map_info.origin.position.y
        free=self.map==0
        if np.count_nonzero(free)<100: return []
        unknown=self.map==-1
        kernel=np.array([[0,1,0],[1,0,1],[0,1,0]],dtype=np.int8)
        nu=ndimage.convolve(unknown.astype(np.int8),kernel,mode='constant',cval=0)
        fm=free&(nu>0); f_rc=np.argwhere(fm)
        if len(f_rc)<10: return []
        # v16: 采样步长2(原4)+BFS邻域3(原2)彻底修复聚类悖论
        f=[(rr,cc) for i,(rr,cc) in enumerate(f_rc) if i%2==0]
        if len(f)<5: f=[(rr,cc) for rr,cc in f_rc[:5000]]
        fs=set(f); clusters=[]; vis=set()
        for cell in f:
            if cell in vis: continue
            cl=[]; q=deque([cell]); vis.add(cell)
            while q:
                rr,cc=q.popleft(); cl.append((rr,cc))
                for dr in [-3,-2,-1,0,1,2,3]:
                    for dc in [-3,-2,-1,0,1,2,3]:
                        nr,nc=rr+dr,cc+dc
                        if (nr,nc) in fs and (nr,nc) not in vis:
                            vis.add((nr,nc)); q.append((nr,nc))
            if len(cl)>=5: clusters.append(cl)    # v17: 5像素(原10, ~0.5m宽门缝)
        return [(mc*r+ox+r/2, mr*r+oy+r/2, len(cl))
                for cl in clusters
                for mr in [sum(c[0] for c in cl)/len(cl)]
                for mc in [sum(c[1] for c in cl)/len(cl)]]
    def _score_frontier(self, wx, wy, size):
        dx=wx-self.pose.x; dy=wy-self.pose.y; dist=math.hypot(dx,dy)
        he=abs(math.atan2(math.sin(math.atan2(dy,dx)-self.yaw),math.cos(math.atan2(dy,dx)-self.yaw)))
        return W_GAIN*math.log1p(size)/math.log1p(100) - W_DIST*min(dist/FT_DIST_DENOM,1.0) - W_TURN*he/math.pi
    def _los_lookahead(self):
        if not self.path or self.map is None: return None
        mi=self.map_info; r=mi.resolution; ox=mi.origin.position.x; oy=mi.origin.position.y
        px,py=self.pose.x,self.pose.y
        for i in range(len(self.path)-1,-1,-1):
            wx,wy=self.path[i]; dist=math.hypot(wx-px,wy-py)
            if dist<0.8 and i>0: continue
            if dist>LOS_MAX: continue   # v17: 8m前瞻(原5m)
            if not self._line_collision(px,py,wx,wy): return (wx,wy)
        for i in range(len(self.path)):
            wx,wy=self.path[i]
            if not self._line_collision(px,py,wx,wy): return (wx,wy)
        return None
    def _line_collision(self, x1,y1,x2,y2):
        if self.map is None or self.map_info is None: return True
        mi=self.map_info; r=mi.resolution; ox=mi.origin.position.x; oy=mi.origin.position.y
        H,W=self.map.shape
        ix1,iy1=int((x1-ox)/r),int((y1-oy)/r); ix2,iy2=int((x2-ox)/r),int((y2-oy)/r)
        dx,dy=abs(ix2-ix1),abs(iy2-iy1); sx=1 if ix2>ix1 else -1; sy=1 if iy2>iy1 else -1
        err=dx-dy; x,y=ix1,iy1
        for _ in range(max(dx,dy)+1):
            if not(0<=x<W and 0<=y<H): return True
            if self.map[y,x]>50: return True
            if x==ix2 and y==iy2: break
            e2=2*err
            if e2>-dy: err-=dy; x+=sx
            if e2<dx: err+=dx; y+=sy
        return False

    # ═══════════════════
    # 主循环
    # ═══════════════════
    def _run(self):
        try: self._run_impl()
        except Exception as e:
            self.get_logger().error(f'CRASH in _run: {e}', throttle_duration_sec=1.0)

    def _run_impl(self):
        if self.pose is None: return
        c = Twist(); now = time.time()
        self._speed_limit = MAX_V   # 每tick重置

        # v22: 位置跟踪 (震荡检测用)
        self._recent_positions.append((self.pose.x, self.pose.y))

        # v22: 震荡检测 — 30个采样(~1.5s)内的位移范围<0.5m → 原地踏步
        if len(self._recent_positions) >= 30:
            xs = [p[0] for p in self._recent_positions]
            ys = [p[1] for p in self._recent_positions]
            span = math.hypot(max(xs)-min(xs), max(ys)-min(ys))
            if span < 0.5 and self.state == 'EXPLORE' and self._force_straight_t <= 0:
                self._stuck += 0.5  # v22: 加速stuck累积, 更快触发逃脱

        # ═══ 多层安全 (最高优先级, 永不屏蔽) ═══
        # 硬刹车后退中
        if self._back_t > 0:
            self._back_t -= 0.05
            self._stuck = 0.0
            self._post_brake_full = 0.0   # 中断post_brake, 重置状态
            c.linear.x = -0.5
            c.angular.z = getattr(self, '_back_dir', 0.8)
            self.pub.publish(c); return

        # 三层安全检查 (硬刹车/预减速在这里面)
        if self._safety_check(c):
            self.pub.publish(c); return

        # ── diag ──
        if now - self._diag_t > 2.0:
            self._diag_t = now
            self.get_logger().info(
                f'[DIAG] F_min={self._front_min:.2f}m {self.state} '
                f'o={self._odom_n} bk={self._back_t:.1f} pt={self._post_brake_t:.1f} '
                f'sk={self._stuck:.1f} e={self._stuck_escalate}')

        # ── post_brake 逃脱转弯 (v17: 用_post_brake_full防半程bug) ──
        if self._post_brake_t > 0:
            if self._post_brake_full <= 0:
                self._post_brake_full = self._post_brake_t  # 记录初始值, 只做一次
            self._post_brake_t -= 0.05
            self.path = []; self._path_target = None
            self._stuck = 0.0
            # 前半段: 后退+转弯; 后半段: 前进+转弯
            if self._post_brake_t > self._post_brake_full * 0.5:
                c.linear.x = -0.15; c.angular.z = self._back_dir * 1.2
            else:
                c.linear.x = 0.35; c.angular.z = self._back_dir * 0.4
            if self._post_brake_t <= 0 and self.pose is not None:
                self._post_brake_full = 0.0  # 重置
                mk = (round(self.pose.x/1.5), round(self.pose.y/1.5))
                self._vst.add(mk); self._brake_count = 0
                if self._stuck_straight_pending > 0:
                    self._force_straight_dir = self.yaw
                    self._force_straight_t = self._stuck_straight_pending
                    self._stuck_straight_pending = 0.0
                    self.get_logger().info('Post-brake→force_straight (stuck recovery)')
                else:
                    # v18: CHASE模式下force_straight朝向目标
                    if self.state == 'CHASE' and self.fusion_tgt is not None:
                        tp = self.fusion_tgt.pose.position
                        self._force_straight_dir = math.atan2(tp.y - self.pose.y, tp.x - self.pose.x)
                        self.get_logger().info('Post-brake→CHASE redirect toward target')
                    else:
                        self._force_straight_dir = self.yaw
                    self._force_straight_t = 4.0
            self.pub.publish(c); return

        # ── v22: 定期环视找球 (EXPLORE模式下每~20s快速旋转180°环视) ──
        if self.state == 'EXPLORE' and self._force_straight_t <= 0 and self._back_t <= 0 and self._post_brake_t <= 0:
            self._target_scan_t += 0.05
            if self._target_scan_t > 20.0:
                c.linear.x = 0.0; c.angular.z = 1.2
                self.pub.publish(c)
                if self._target_scan_t > 21.6:  # 旋转1.6s≈190°
                    self._target_scan_t = 0.0
                    self._stuck = max(0.0, self._stuck - 2.0)  # 环视后减stuck
                    self.get_logger().info('Target scan done → resume explore')
                return
        elif self.state != 'EXPLORE':
            self._target_scan_t = 0.0  # 非探索状态重置

        # ── 目标检测 (v18: 10s超时+CHASE宽限期+fusion_tgt保鲜20s) ──
        det_fresh = False; det_recent = False
        if self.last_det is not None:
            dt = (self.get_clock().now() - self.last_det).nanoseconds / 1e9
            det_fresh = dt < 10.0     # v18: 放宽到10s (原4s, YOLO ~2Hz检测+转弯遮挡)
            det_recent = dt < 20.0    # v18: 20s内有过检测, 用于fusion保鲜辅助

        # fusion_tgt保鲜检查: 上次3D更新是否在20s内
        tgt_fresh = (now - self._fusion_tgt_time) < 20.0 if self._fusion_tgt_time > 0 else False

        # ACQUIRE冷却: 上一次超时后5s内不重新进入
        if self._acquire_cooldown_t > 0:
            self._acquire_cooldown_t -= 0.05
            if self._acquire_cooldown_t <= 0 and now - self._log_t > 1.0:
                self._log_t = now
                self.get_logger().info('ACQUIRE cooldown ended')

        # ACQUIRE超时: 等了10s还没3D→放弃, 冷却5s
        if self._acquire_start > 0 and now - self._acquire_start > 10.0:
            self._acquire_start = 0.0
            self._acquire_cooldown_t = 5.0  # 5s内不重新ACQUIRE
            self.get_logger().warn('ACQUIRE timeout, cooling 5s')

        if (det_fresh and self.fusion_tgt is None
            and self.state not in ('CHASE', 'REACHED')
            and self._acquire_cooldown_t <= 0):   # 冷却中跳过
            if self._acquire_start <= 0:
                self._acquire_start = now
                self.get_logger().info(f'ACQUIRE: waiting for fusion 3D... (was {self.state})')
            self._stuck = 0.0
            c.linear.x = 0.0; c.angular.z = 0.35
            self.pub.publish(c); return
        elif not det_fresh:
            self._acquire_start = 0.0
            if self._acquire_cooldown_t < 0.1:  # YOLO不再检测到球时快速结束冷却
                self._acquire_cooldown_t = 0.0

        # ── v18: CHASE进入/退出逻辑 (宽限期防短暂丢失) ──
        if det_fresh and self.fusion_tgt is not None:
            if self.state not in ('CHASE', 'REACHED'):
                self.state = 'CHASE'; self.path = []; self._path_target = None
                self._acquire_start = 0.0; self._chase_lost_since = 0.0
                self._stuck = 0.0; self._stuck_escalate = 0
                self._chase_plan = []; self._chase_plan_target = None
                self._chase_start = now
                self.get_logger().info('→CHASE (target locked)')
        elif self.state == 'CHASE':
            # v18: 仅在YOLO丢失+fusion过期时才退出, 否则保持CHASE
            if not det_fresh and not tgt_fresh:
                # YOLO也丢了, fusion也过期了 (>20s) → 真正丢失
                self.state = 'EXPLORE'; self.path = []; self._path_target = None
                self._chase_lost_since = 0.0; self._chase_plan = []
                self._stuck = 0.0; self._stuck_escalate = 0
                self._bias_angle = None; self._no_ft_count = 0  # v18: 重置探索状态
                self.get_logger().warn('CHASE→EXPLORE (target truly lost: no det+stale fusion)')
            elif not det_fresh and tgt_fresh:
                # YOLO短暂丢失但fusion位置还在 → 继续CHASE (宽限期)
                if self._chase_lost_since <= 0:
                    self._chase_lost_since = now
                lost_dur = now - self._chase_lost_since
                if lost_dur > 10.0:
                    self.state = 'EXPLORE'; self.path = []; self._path_target = None
                    self._chase_lost_since = 0.0; self._chase_plan = []
                    self._stuck = 0.0; self._stuck_escalate = 0
                    self._bias_angle = None; self._no_ft_count = 0  # v18: 重置探索状态
                    self.get_logger().warn(f'CHASE→EXPLORE (YOLO lost {lost_dur:.0f}s, fusion stale soon)')
            else:
                # det_fresh恢复 → 重置宽限期
                self._chase_lost_since = 0.0

        # ── 强制直行 (所有状态通用: CHASE→朝目标, EXPLORE→朝原方向) ──
        if self._force_straight_t > 0:
            self._force_straight_t -= 0.05
            # v18: CHASE模式朝向目标
            if self.state == 'CHASE' and self.fusion_tgt is not None:
                tp = self.fusion_tgt.pose.position
                fdir = math.atan2(tp.y - self.pose.y, tp.x - self.pose.x)
            else:
                fdir = self._force_straight_dir
            gx = self.pose.x + 5.0 * math.cos(fdir)
            gy = self.pose.y + 5.0 * math.sin(fdir)
            if self.state == 'CHASE':
                v, w = self._potential_field_chase(gx, gy)
            else:
                v, w = self._potential_field(gx, gy)
            c.linear.x = max(0.5, v)    # v21: 最低0.5 确保前进推力
            c.angular.z = w             # 完整APF转向
            if self._force_straight_t <= 0:
                self.get_logger().info('force straight done')
            self.pub.publish(c); return

        # ── SPIN_WAIT ──
        if self.state == 'SPIN_WAIT':
            spun = self._spin > FULL_CIRCLE * 1.2
            map_ok = self._map_ready()
            tmout = (now - self._spin_start) > SPIN_TIMEOUT
            if (spun and map_ok) or tmout:
                self._stuck = 0.0; self._no_ft_count = 0; self._post_brake_t = 0.0; self.state = 'EXPLORE'
                self._stuck_check_t = 0.0; self._stuck_check_pos = None  # v20: 重置检测窗口
                free = np.count_nonzero(self.map == 0) if self.map is not None else 0
                rsn = 'map_ok' if map_ok else f'timeout({now-self._spin_start:.0f}s)'
                self.get_logger().info(f'→EXPLORE ({rsn}, spin={self._spin:.1f}rad, free={free})')
                self.pub.publish(Twist()); return
            if now - self._spin_log > 2.0:
                self._spin_log = now
                fn = np.count_nonzero(self.map == 0) if self.map is not None else 0
                self.get_logger().info(f'SPIN_WAIT: {self._spin:.1f}/{FULL_CIRCLE*1.2:.1f}rad free={fn}')
            c.angular.z = SPIN_SPD; self.pub.publish(c); return

        # ── CHASE (v19: 沿墙滑动 + 到达重规划 + 更早避障) ──
        if self.state == 'CHASE':
            self._stuck = max(0.0, self._stuck - 0.1)
            self._stuck_escalate = 0

            if self.fusion_tgt is None:
                c.linear.x = 0.0; c.angular.z = 0.35; self.pub.publish(c); return
            tp = self.fusion_tgt.pose.position
            d = math.hypot(tp.x-self.pose.x, tp.y-self.pose.y)
            chase_dur = now - self._chase_start if self._chase_start > 0 else 0
            if d < GOAL_DIST and chase_dur > 3.0:
                # v22: 抵达验证 — 记录机器人实际位置和目标EMA位置, 供调试
                self.get_logger().info(f'REACHED: robot=({self.pose.x:.2f},{self.pose.y:.2f}) '
                                       f'target=({tp.x:.2f},{tp.y:.2f}) d={d:.2f}m chase_dur={chase_dur:.1f}s')
                self.state = 'REACHED'; self.pub.publish(Twist())
                self.get_logger().info(f'到达! {d:.1f}m'); return
            ang_tgt = math.atan2(tp.y-self.pose.y, tp.x-self.pose.x)
            gx = tp.x - GOAL_DIST*math.cos(ang_tgt)
            gy = tp.y - GOAL_DIST*math.sin(ang_tgt)

            # v19: 前方有障碍时的绕过决策
            blocked = self._front_min < 2.0      # v19: 更早触发(原1.5)
            hard_blocked = self._front_min < 1.2  # v19: 严重阻挡
            need_bypass = blocked and d > GOAL_DIST + 0.5
            need_replan = (not self._chase_plan or
                          now - self._fplan_t > 4.0 or  # v19: 更频繁重规划(原8s)
                          getattr(self, '_chase_replan_needed', False))

            if need_bypass and self._map_ready():
                if need_replan:
                    self._chase_replan_needed = False
                    rw = self._astar(self.pose.x, self.pose.y, gx, gy)
                    if rw and len(rw) > 2:
                        self._chase_plan = rw
                        self._chase_plan_target = rw[-1]
                        self._fplan_t = now
                        self.get_logger().info(
                            f'CHASE A* {len(rw)}pts → ({gx:.1f},{gy:.1f}) F={self._front_min:.1f}m')
                    else:
                        self._chase_plan = []

                if self._chase_plan and self._chase_plan_target:
                    los = self._los_lookahead_chase()
                    if los:
                        gx_use, gy_use = los
                    else:
                        gx_use, gy_use = self._chase_plan_target
                    # v19: 到达路径终点 → 标记立即重规划(不清除路径, 下个tick重规划)
                    dtg_plan = math.hypot(self._chase_plan_target[0]-self.pose.x,
                                          self._chase_plan_target[1]-self.pose.y)
                    if dtg_plan < 1.0:
                        self._chase_replan_needed = True
                else:
                    # v19: A*失败 → 沿墙滑动 (面向目标侧向, 沿开放方向走)
                    gx_use, gy_use = self._tangent_bypass(gx, gy, tp)
            elif hard_blocked and not self._map_ready():
                # v19: 地图未就绪但被硬阻挡 → 沿墙滑动
                gx_use, gy_use = self._tangent_bypass(gx, gy, tp)
            else:
                self._chase_plan = []; self._chase_plan_target = None
                self._chase_replan_needed = False
                gx_use, gy_use = gx, gy

            v, w = self._potential_field_chase(gx_use, gy_use)
            c.linear.x = v; c.angular.z = w; self.pub.publish(c); return

        # ── REACHED ──
        if self.state == 'REACHED':
            if now - self._log_t > 5.0: self._log_t = now; self.get_logger().info('任务完成')
            self.pub.publish(Twist()); return

        # ═══ EXPLORE ═══

        # ── spin-trap检测: 高角速+低线速>2.5s → 强制直行 ──
        if self._force_straight_t <= 0 and abs(c.angular.z) > 0.5 and abs(c.linear.x) < 0.10:
            self._spin_trap_t += 0.05
            if self._spin_trap_t > SPIN_TRAP_LIMIT:
                self.get_logger().warn(f'SPIN-TRAP! {self._spin_trap_t:.1f}s → force straight')
                if self.scan_ranges is not None and self._scan_valid > 5:
                    n = len(self.scan_ranges); mid = n//2
                    best_i, best_d = mid, 0.0
                    for k in range(0, n, max(1, n//180)):
                        d = self.scan_ranges[k]
                        if 0.5 < d < 30 and not math.isinf(d) and d > best_d:
                            best_d = d; best_i = k
                    self._force_straight_dir = self.yaw + (-math.pi + best_i * 2.0 * math.pi / n)
                    self._force_straight_t = 4.0  # spin-trap
                else:
                    self._force_straight_dir = self.yaw
                    self._force_straight_t = 4.0  # spin-trap fallback
                self._spin_trap_t = 0.0
        else:
            self._spin_trap_t = max(0.0, self._spin_trap_t - 0.025)

        # ── thrashing检测 ──
        if self._last_yaw is not None:
            dy = math.atan2(math.sin(self.yaw - self._last_yaw),
                           math.cos(self.yaw - self._last_yaw))
            self._thrash_w.append(1 if dy > 0 else -1)
        self._last_yaw = self.yaw
        self._thrash_t += 0.05
        if self._thrash_t > 1.5:
            sign_changes = sum(1 for j in range(1, len(self._thrash_w))
                              if self._thrash_w[j] * self._thrash_w[j-1] < 0)
            if sign_changes > 5 and self._force_straight_t <= 0 and self.scan_ranges is not None:
                n = len(self.scan_ranges); mid = n//2
                self._force_straight_dir = self.yaw
                best_d = 0.0
                for k in range(mid-60, mid+61):
                    d = self.scan_ranges[k % n]
                    if 0.5 < d < 30 and not math.isinf(d) and d > best_d:
                        best_d = d
                        self._force_straight_dir = self.yaw + (-math.pi + k * 2.0 * math.pi / n)
                self._force_straight_t = 4.0   # thrash
                self.get_logger().warn(f'THRASH detected! force straight {self._force_straight_dir:.1f}rad')
            self._thrash_w.clear(); self._thrash_t = 0.0

        # ── 前沿路径跟随 ──
        if self.path and self._path_target:
            if self._stuck > 8.0 or (now - self._fplan_t) > 25.0:
                self.get_logger().warn(f'路径不通, 放弃 (stuck={self._stuck:.1f}s ttl={now-self._fplan_t:.0f}s)')
                self.path = []; self._path_target = None
                if self._last_goal: self._vst.add(self._last_goal)
                self._stuck = 0.0
                self._stuck_check_t = 0.0; self._stuck_check_pos = None  # v20: 重置窗口
                self._fplan_t = 0.0    # v17.3: 强制立即重规划, 消除0.5s停顿
            else:
                los = self._los_lookahead()
                gx_tgt, gy_tgt = los if los else self._path_target
                v, w = self._potential_field(gx_tgt, gy_tgt)
                c.linear.x = v; c.angular.z = w
                dtg = math.hypot(self._path_target[0]-self.pose.x, self._path_target[1]-self.pose.y)
                if dtg < 1.0 and (now - self._fplan_t) > 2.0:
                    self.path = []; self._path_target = None
                    # v22: 到达前沿→标记3x3网格, 并清除该前沿的重规划计数
                    if self._last_goal:
                        gx_cell, gy_cell = self._last_goal
                        for dcx in [-1, 0, 1]:
                            for dcy in [-1, 0, 1]:
                                self._vst.add((gx_cell+dcx, gy_cell+dcy))
                        # v22: 到达后清除尝试计数
                        self._frontier_attempts.pop((gx_cell, gy_cell), None)
                    self.get_logger().info(f'到达前沿 #{self._cnt}')
                    self._stuck = 0.0; self._brake_count = 0; self._stuck_escalate = 0
                    self._stuck_check_t = 0.0; self._stuck_check_pos = None
                    self._bias_angle = None
                    self._target_scan_t = 0.0   # v22: 到达前沿后重置环视计时
            self.pub.publish(c); return

        # ── 前沿规划 (v22: 重规划计数+防止死循环) ──
        los_recent = (now - self._los_fail_t) < 1.0
        need_replan = ((self._path_target is None and not los_recent) or
                       now - self._fplan_t > 12.0)
        if now - self._last_ft > 0.5 and need_replan:
            self._last_ft = now
            clusters = self._frontier_clusters()
            if clusters:
                scored = []
                for wx, wy, size in clusters:
                    mk = (round(wx/1.5), round(wy/1.5))
                    if mk in self._vst: continue
                    # v22: 重规划≥3次的前沿→加入vst, 防止死循环
                    if self._frontier_attempts.get(mk, 0) >= 3:
                        self._vst.add(mk)
                        self.get_logger().info(f'Frontier {mk} attempted 3x → blacklisted',
                                              throttle_duration_sec=3.0)
                        continue
                    scored.append((self._score_frontier(wx, wy, size), wx, wy, mk, size))
                if scored:
                    scored.sort(reverse=True)
                    found = False
                    for rank in range(min(5, len(scored))):
                        _, gx, gy, mk, size = scored[rank]
                        rw = self._astar(self.pose.x, self.pose.y, gx, gy)
                        if rw:
                            self.path = rw; self._path_target = (gx, gy)
                            self._cnt += 1; self._stuck = 0.0; self._no_ft_count = 0
                            self._spin_scan_t = 0.0
                            self._fplan_t = now; self._los_fail_t = 0.0; self._last_goal = mk
                            # v22: 记录前沿尝试次数
                            self._frontier_attempts[mk] = self._frontier_attempts.get(mk, 0) + 1
                            self.get_logger().info(f'→({gx:.1f},{gy:.1f}) d={math.hypot(gx-self.pose.x,gy-self.pose.y):.1f}m sz={size} #{self._cnt}  r={rank} at={self._frontier_attempts[mk]}')
                            self.pub.publish(c); found = True
                            break
                    if found: return
                else:
                    # v21: 全在黑名单→push探索到新区域(不清vst, 自然扩展地图)
                    self.get_logger().info(f'All frontiers blacklisted → push (vst={len(self._vst)})',
                                           throttle_duration_sec=5.0)
            self._no_ft_count += 1

        # ── stuck 处理 (v16: 先退后冲, 避免顶墙) ──
        if self._stuck > 8.0 and self._post_brake_t <= 0 and self._back_t <= 0:
            self._stuck_escalate += 1
            esc = self._stuck_escalate
            self.get_logger().warn(f'stuck={self._stuck:.1f}s esc={esc} → escape')
            self._bias_angle = self.yaw
            self._stuck = 0.0; self.path = []; self._no_ft_count = 3
            self._stuck_check_t = 0.0; self._stuck_check_pos = None  # v20: 重置窗口

            if esc >= 3:
                if self.pose is not None:
                    mk = (round(self.pose.x/1.5), round(self.pose.y/1.5))
                    self._vst.add(mk)
                self._stuck_escalate = 0
                self._post_brake_t = 8.0
                self._back_dir = 1.0 if np.random.random() > 0.5 else -1.0
                self.get_logger().error('STUCKx3! 大撤退')
            else:
                # v16: 先倒退+转弯1.2s建立物理空间, 再直行
                self._post_brake_t = 2.0           # 短退避
                self._back_dir = 1.0 if np.random.random() > 0.5 else -1.0
                # 退避完成后自动触发force_straight (在post_brake退出时设置)
                self._stuck_straight_pending = 5.0  # 退避后直行5s
                self.get_logger().info(f'STUCK esc={esc}: back then straight')
            self.pub.publish(c); return

        # ── 无前沿 ──
        if self._no_ft_count > 5:
            if now - self._log_t > 3.0:
                self._log_t = now
                mode = 'push' if self._no_ft_count < 20 else 'spin-scan'
                self.get_logger().info(f'无前沿x{self._no_ft_count} → {mode}')

            if self._no_ft_count >= 20:
                c.linear.x = 0.0; c.angular.z = 0.6
                self._spin_scan_t += 0.05
                self._spin_scan_total += 0.05
                if self._spin_scan_t > 8.0:
                    # v22: soft-clear vst — 保留50%防止立即回到已探索区域
                    if len(self._vst) > 20:
                        keep = list(self._vst)[:len(self._vst)//2]
                        self._vst.clear()
                        for k in keep:
                            self._vst.add(k)
                        self.get_logger().info(f'spin-scan: _vst soft-clear kept {len(self._vst)}')
                    else:
                        self._vst.clear()
                        self.get_logger().info('spin-scan: _vst cleared, retry')
                    # v22: 也清理旧的前沿尝试记录
                    old_keys = [k for k, v in self._frontier_attempts.items() if v >= 2]
                    for k in old_keys:
                        del self._frontier_attempts[k]
                    self._no_ft_count = 0; self._spin_scan_t = 0.0
                if self._spin_scan_total > 12.0:
                    best_dir = self.yaw
                    if self.scan_ranges is not None and self._scan_valid > 5:
                        n = len(self.scan_ranges)
                        best_i, best_d = n//2, 0.0
                        for i in range(0, n, max(1, n//180)):
                            d = self.scan_ranges[i]
                            if 0.5 < d < 30 and not math.isinf(d) and d > best_d:
                                best_d = d; best_i = i
                        best_dir = self.yaw + (-math.pi + best_i * 2.0 * math.pi / n)
                    self._scan_push_dir = best_dir
                    self._scan_push_t = 5.0
                    self._spin_scan_total = 0.0; self._spin_scan_t = 0.0
                    self._push_tgt = None
                    self.get_logger().warn(f'SPIN-SCAN TIMEOUT! push escape dir={best_dir:.1f}')
                self.pub.publish(c); return

            if self._scan_push_t > 0:
                self._scan_push_t -= 0.05
                gx = self.pose.x + 5.0 * math.cos(self._scan_push_dir)
                gy = self.pose.y + 5.0 * math.sin(self._scan_push_dir)
                v, w = self._potential_field(gx, gy)
                c.linear.x = max(0.7, v)    # v21: 最低0.7 更积极push
                c.angular.z = w             # 完整APF (v14:未限制)
                if self._scan_push_t <= 0:
                    # v22: soft-clear vst (保留50%)
                    if len(self._vst) > 20:
                        keep = list(self._vst)[:len(self._vst)//2]
                        self._vst.clear()
                        for k in keep: self._vst.add(k)
                    else:
                        self._vst.clear()
                    self._no_ft_count = 0
                    self._bias_angle = None
                    self._stuck = 0.0; self._stuck_check_t = 0.0; self._stuck_check_pos = None
                    self.get_logger().info('spin-scan escape done → EXPLORE')
                self.pub.publish(c); return

            # push 模式: 0.5s防抖 + 5m远处目标 + v22方向多样性
            if now - self._push_tgt_t > 0.5:
                if self.scan_ranges is not None and self._scan_valid > 5:
                    n = len(self.scan_ranges); mid = n//2
                    fwd_range = 2*n//3
                    best_i, best_score = mid, -9.0
                    for i in range(mid - fwd_range//2, mid + fwd_range//2):
                        d = self.scan_ranges[i%n]
                        if not (0.5 < d < 30): d = 0.5
                        if math.isinf(d): d = 0.5
                        w_angle = -math.pi + (i%n)*2.0*math.pi/n
                        bias_penalty = 0.0
                        if self._bias_angle is not None:
                            err = abs(math.atan2(math.sin(w_angle - self._bias_angle),
                                                 math.cos(w_angle - self._bias_angle)))
                            bias_penalty = max(0, 1.0 - err/math.pi) * 10.0
                        # v22: 近期push方向惩罚 (防止反复走同一边)
                        recent_penalty = 0.0
                        world_dir = self.yaw + w_angle
                        for recent_dir in self._recent_push_dirs:
                            diff = abs(math.atan2(math.sin(world_dir - recent_dir),
                                                  math.cos(world_dir - recent_dir)))
                            if diff < 0.5:  # ~30°内
                                recent_penalty += 5.0 * (1.0 - diff/0.5)
                        score = d - bias_penalty - recent_penalty
                        if score > best_score:
                            best_score = score; best_i = i%n
                    self._push_tgt = self.yaw + (-math.pi + best_i*2.0*math.pi/n)
                    # v22: 记录push方向
                    self._recent_push_dirs.append(self._push_tgt)
                else:
                    self._push_tgt = self.yaw
                self._push_tgt_t = now

            if self._push_tgt is not None:
                gx_tgt = self.pose.x + 5.0*math.cos(self._push_tgt)
                gy_tgt = self.pose.y + 5.0*math.sin(self._push_tgt)
            else:
                gx_tgt = self.pose.x + 5.0*math.cos(self.yaw)
                gy_tgt = self.pose.y + 5.0*math.sin(self.yaw)
            v, w = self._potential_field(gx_tgt, gy_tgt)
            c.linear.x = max(0.6, v); c.angular.z = w  # v21: push保底0.6m/s
            self.pub.publish(c); return

        # ── 兜底 ──
        fwd_angle = self.yaw
        if self._bias_angle is not None:
            err = abs(math.atan2(math.sin(fwd_angle - self._bias_angle),
                                 math.cos(fwd_angle - self._bias_angle)))
            if err < 0.5:
                fwd_angle = self.yaw + (self._back_dir * math.pi/2)
        gx_tgt = self.pose.x + 5.0*math.cos(fwd_angle)
        gy_tgt = self.pose.y + 5.0*math.sin(fwd_angle)
        v, w = self._potential_field(gx_tgt, gy_tgt)
        c.linear.x = v; c.angular.z = w
        self.pub.publish(c)

def main(): rclpy.init(); rclpy.spin(AutoExplorer())
if __name__ == '__main__': main()
